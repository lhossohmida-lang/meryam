{
  "name": "walida",
  "private": true,
  "version": "1.0.0",
  "description": "Walida - Luxury Children's Clothing PWA",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "generate:apk": "node generate-apk.mjs https://mreim-3027a.web.app",
    "build:exe": "npx electron-builder --win --config electron-builder.json && node -e \"const fs = require('fs'); fs.mkdirSync('public/exe', { recursive: true }); fs.mkdirSync('dist/exe', { recursive: true }); fs.copyFileSync('dist-exe/Baraa Kids Setup 1.0.0.exe', 'public/exe/baraa-kids-setup.exe'); fs.copyFileSync('dist-exe/Baraa Kids Setup 1.0.0.exe', 'dist/exe/baraa-kids-setup.exe'); console.log('EXE copied successfully!');\"",
    "electron:dev": "electron electron-main.js",
    "deploy": "firebase deploy"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@google/generative-ai": "^0.24.1",
    "firebase": "^10.13.2",
    "framer-motion": "^11.11.7",
    "lucide-react": "^0.451.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "firebase-tools": "^15.19.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  }
}
