# =========================================================
#  Walida — Environment Variables
# ---------------------------------------------------------
#  Copy to `.env` and fill in.
# =========================================================

# -- Cloudinary (required for image / .glb uploads) -------
# 1. Create free account at https://cloudinary.com
# 2. Dashboard → copy "Cloud name"
# 3. Settings → Upload → Add upload preset → Signing mode: Unsigned → Save
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# -- AI pipeline (optional, defaults to local simulator) --
# Switch the 2D→3D pipeline from simulated → real Tripo3D
VITE_USE_REAL_3D_API=false
VITE_TRIPO3D_API_KEY=

# -- Gemini AI (required for AI chat + product generation) --
# Get free API key: https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=
